{
  "manifest_version": 3,
  "name": "QR P2P File Share",
  "version": "1.0",
  "description": "Share photos, videos, documents, and media directly between devices with QR code setup and peer-to-peer transfer. No account, no cloud upload, and no third-party server.",
  "action": {
    "default_title": "Open P2P Share",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "permissions": [],
  "host_permissions": [],
  "browser_specific_settings": {
    "gecko": {
      "id": "p2p-share@nikunj.local",
      "strict_min_version": "121.0"
    }
  }
}
